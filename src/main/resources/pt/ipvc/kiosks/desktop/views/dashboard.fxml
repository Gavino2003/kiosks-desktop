<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.ipvc.kiosks.desktop.controller.DashboardController"
            styleClass="dashboard-root">

    <!-- Top bar -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Kiosks BackOffice" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" styleClass="topbar-user"/>
            <Label text=" | " styleClass="topbar-sep"/>
            <Label fx:id="roleLabel" styleClass="topbar-role"/>
            <Button text="Sign out" onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox fx:id="sideMenu" styleClass="sidebar" spacing="4" minWidth="180">
            <Label text="MAIN" styleClass="sidebar-section"/>
            <Button fx:id="btnDashboard" text="Dashboard"  onAction="#showHome"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnOrders"    text="Orders"     onAction="#showOrders"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnStock"     text="Stock"      onAction="#showStock"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Separator fx:id="sepGestao"/>
            <Label fx:id="lblGestao" text="MANAGEMENT" styleClass="sidebar-section"/>
            <Button fx:id="btnProducts"  text="Products"   onAction="#showProducts"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnStores"    text="Stores"     onAction="#showStores"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnKiosks"    text="Kiosks"     onAction="#showKiosks"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="btnUsers"     text="Employees"  onAction="#showUsers"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- Content area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
