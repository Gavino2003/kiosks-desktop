<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.StoresController"
      styleClass="view-root" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Store Management" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tableStores" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"   text="Store Name" prefWidth="200"/>
            <TableColumn fx:id="colType"   text="Type"       prefWidth="110"/>
            <TableColumn fx:id="colCity"   text="City"       prefWidth="140"/>
            <TableColumn fx:id="colActive" text="Status"     prefWidth="90"/>
        </columns>
        <placeholder><Label text="No stores registered."/></placeholder>
    </TableView>

    <VBox styleClass="form-card" spacing="10">
        <Label fx:id="lblFormTitle" text="New Store" styleClass="card-title"/>
        <GridPane hgap="12" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
            </columnConstraints>
            <HBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="2">
                <Label text="Name"/>
                <Label text=" *" styleClass="required-mark"/>
            </HBox>
            <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label text="Type:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <ComboBox fx:id="cmbType" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtAddress" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="City:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="txtCity" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            <Label text="Postal Code:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="txtPostal" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
        <Label text="* Required field" styleClass="required-hint"/>
        <HBox spacing="8">
            <Button fx:id="btnSave"       text="Save Store"         onAction="#handleSave"         styleClass="btn-primary"/>
            <Button text="Enable / Disable" onAction="#handleToggleActive" styleClass="btn-secondary"/>
            <Button fx:id="btnDelete"     text="Delete"             onAction="#handleDelete"       styleClass="btn-danger"/>
            <Button fx:id="btnCancelEdit" text="Cancel"             onAction="#handleCancelEdit"   styleClass="btn-secondary"/>
        </HBox>
        <Label fx:id="lblStatus" styleClass="status-label" wrapText="true"/>
    </VBox>
</VBox>
