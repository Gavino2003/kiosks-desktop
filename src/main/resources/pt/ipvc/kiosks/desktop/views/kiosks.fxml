<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.KiosksController"
      styleClass="view-root" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Kiosk Management" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tableKiosks" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"   text="Name"          prefWidth="160"/>
            <TableColumn fx:id="colSerial" text="Serial No."    prefWidth="130"/>
            <TableColumn fx:id="colModel"  text="Model"         prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Status"        prefWidth="110"/>
            <TableColumn fx:id="colStore"  text="Store"         prefWidth="160"/>
        </columns>
        <placeholder><Label text="No kiosks registered."/></placeholder>
    </TableView>

    <VBox styleClass="form-card" spacing="10">
        <Label fx:id="lblFormTitle" text="New Kiosk" styleClass="card-title"/>
        <GridPane hgap="12" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="160" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="160" hgrow="ALWAYS"/>
            </columnConstraints>
            <HBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="2">
                <Label text="Name"/>
                <Label text=" *" styleClass="required-mark"/>
            </HBox>
            <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <HBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="2">
                <Label text="Store"/>
                <Label text=" *" styleClass="required-mark"/>
            </HBox>
            <ComboBox fx:id="cmbStore" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <Label text="Serial No.:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtSerial" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="Model:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="txtModel" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="cmbStatus" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
        <Label text="* Required field" styleClass="required-hint"/>
        <HBox spacing="8">
            <Button fx:id="btnSave"       text="Save Kiosk" onAction="#handleSave"       styleClass="btn-primary"/>
            <Button fx:id="btnDelete"     text="Delete"     onAction="#handleDelete"     styleClass="btn-danger"/>
            <Button fx:id="btnCancelEdit" text="Cancel"     onAction="#handleCancelEdit" styleClass="btn-secondary"/>
        </HBox>
        <Label fx:id="lblStatus" styleClass="status-label" wrapText="true"/>
    </VBox>
</VBox>
