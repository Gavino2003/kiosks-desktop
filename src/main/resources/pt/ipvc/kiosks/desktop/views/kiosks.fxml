<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.KiosksController"
      styleClass="view-root" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Gestão de Quiosques" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Atualizar" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tableKiosks" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"   text="Nome"     prefWidth="160"/>
            <TableColumn fx:id="colSerial" text="Nº Série" prefWidth="130"/>
            <TableColumn fx:id="colModel"  text="Modelo"   prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Estado"   prefWidth="110"/>
            <TableColumn fx:id="colStore"  text="Loja"     prefWidth="160"/>
        </columns>
        <placeholder><Label text="Sem quiosques registados."/></placeholder>
    </TableView>

    <VBox styleClass="form-card" spacing="10">
        <Label fx:id="lblFormTitle" text="Novo Quiosque" styleClass="card-title"/>
        <GridPane hgap="12" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="160" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="160" hgrow="ALWAYS"/>
            </columnConstraints>
            <HBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="2">
                <Label text="Nome"/>
                <Label text=" *" styleClass="required-mark"/>
            </HBox>
            <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <HBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="2">
                <Label text="Loja"/>
                <Label text=" *" styleClass="required-mark"/>
            </HBox>
            <ComboBox fx:id="cmbStore" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <Label text="Nº Série:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtSerial" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="Modelo:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="txtModel" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="cmbStatus" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
        <Label text="* Campo obrigatório" styleClass="required-hint"/>
        <HBox spacing="8">
            <Button fx:id="btnSave"       text="Criar Quiosque" onAction="#handleSave"       styleClass="btn-primary"/>
            <Button fx:id="btnDelete"     text="Apagar"         onAction="#handleDelete"     styleClass="btn-danger"/>
            <Button fx:id="btnCancelEdit" text="Cancelar"       onAction="#handleCancelEdit" styleClass="btn-secondary"/>
        </HBox>
        <Label fx:id="lblStatus" styleClass="status-label" wrapText="true"/>
    </VBox>
</VBox>
