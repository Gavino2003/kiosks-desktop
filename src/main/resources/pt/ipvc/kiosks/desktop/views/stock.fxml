<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.StockController"
      styleClass="view-root" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Warehouse Stock" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
        <Label text="Category:"/>
        <ComboBox fx:id="cmbCategory" prefWidth="180"/>
        <Button text="Filter" onAction="#handleFilter" styleClass="btn-secondary"/>
        <Separator orientation="VERTICAL"/>
        <Label text="Search:"/>
        <TextField fx:id="txtSearch" promptText="product name..." prefWidth="200"/>
    </HBox>

    <TableView fx:id="tableStock" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"     text="Product"   prefWidth="210"/>
            <TableColumn fx:id="colSku"      text="SKU"       prefWidth="110"/>
            <TableColumn fx:id="colCategory" text="Category"  prefWidth="130"/>
            <TableColumn fx:id="colPrice"    text="Price"     prefWidth="80"/>
            <TableColumn fx:id="colQty"      text="Stock"     prefWidth="70"/>
            <TableColumn fx:id="colStatus"   text="Status"    prefWidth="80"/>
        </columns>
        <placeholder><Label text="No products found."/></placeholder>
    </TableView>

    <Label fx:id="lblInfo" styleClass="status-label" wrapText="true"/>

</VBox>
