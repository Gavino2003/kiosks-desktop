<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.OrdersController"
      styleClass="view-root" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Order Management" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <!-- Filters -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
        <Label text="Filter by status:"/>
        <ComboBox fx:id="cmbFilterStatus" prefWidth="130"/>
        <Button text="Filter" onAction="#handleFilter" styleClass="btn-secondary"/>
        <Separator orientation="VERTICAL"/>
        <Label text="Search reference:"/>
        <TextField fx:id="txtSearchRef" promptText="e.g. ORD-2026-AB12CD34" prefWidth="220"
                   onAction="#handleSearch"/>
        <Button text="Search" onAction="#handleSearch" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tableOrders" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colRef"    text="Reference"  prefWidth="170"/>
            <TableColumn fx:id="colStatus" text="Status"     prefWidth="100"/>
            <TableColumn fx:id="colTotal"  text="Total"      prefWidth="90"/>
            <TableColumn fx:id="colStore"  text="Store"      prefWidth="140"/>
            <TableColumn fx:id="colKiosk"  text="Kiosk"      prefWidth="150"/>
            <TableColumn fx:id="colDate"   text="Date"       prefWidth="135"/>
        </columns>
        <placeholder><Label text="No orders found."/></placeholder>
    </TableView>

    <!-- Detail panel -->
    <VBox styleClass="form-card" spacing="10">
        <Label fx:id="lblOrderDetail" styleClass="info-text" wrapText="true"
               text="Select an order to view details."/>
        <!-- Management panel: only visible to ADMIN and MANAGER -->
        <HBox fx:id="paneGestao" spacing="8" alignment="CENTER_LEFT">
            <Label text="Change status to:"/>
            <ComboBox fx:id="cmbNewStatus" prefWidth="140"/>
            <Button text="Update Status" onAction="#handleUpdateStatus" styleClass="btn-primary"/>
        </HBox>
        <Label fx:id="lblStatus" styleClass="status-label" wrapText="true"/>
    </VBox>
</VBox>
