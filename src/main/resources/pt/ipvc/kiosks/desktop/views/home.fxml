<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.HomeController"
      styleClass="view-root" spacing="20">

    <Label text="Dashboard" styleClass="view-title"/>

    <!-- KPI cards row -->
    <HBox spacing="16">
        <VBox styleClass="kpi-card kpi-blue" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="PENDING ORDERS" styleClass="kpi-label"/>
            <Label fx:id="lblPendingOrders" text="—" styleClass="kpi-value"/>
            <Label text="awaiting fulfilment" styleClass="kpi-sub"/>
        </VBox>
        <VBox styleClass="kpi-card kpi-green" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="ACTIVE PRODUCTS" styleClass="kpi-label"/>
            <Label fx:id="lblTotalProducts" text="—" styleClass="kpi-value"/>
            <Label text="across all stores" styleClass="kpi-sub"/>
        </VBox>
        <VBox styleClass="kpi-card kpi-purple" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="ACTIVE KIOSKS" styleClass="kpi-label"/>
            <Label fx:id="lblActiveKiosks" text="—" styleClass="kpi-value"/>
            <Label text="online terminals" styleClass="kpi-sub"/>
        </VBox>
        <VBox styleClass="kpi-card kpi-orange" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="USERS" styleClass="kpi-label"/>
            <Label fx:id="lblTotalUsers" text="—" styleClass="kpi-value"/>
            <Label text="registered accounts" styleClass="kpi-sub"/>
        </VBox>
    </HBox>

    <!-- Quick actions -->
    <VBox styleClass="section-card" spacing="12">
        <Label text="Quick Actions" styleClass="section-title"/>
        <HBox spacing="10">
            <Button text="📦  View Orders"   onAction="#goOrders"   styleClass="quick-btn" prefWidth="160"/>
            <Button text="🛍  Products"       onAction="#goProducts" styleClass="quick-btn" prefWidth="160"/>
            <Button text="🏪  Stores"         onAction="#goStores"   styleClass="quick-btn" prefWidth="160"/>
            <Button text="📟  Kiosks"         onAction="#goKiosks"   styleClass="quick-btn" prefWidth="160"/>
        </HBox>
    </VBox>

    <!-- System info -->
    <VBox styleClass="section-card" spacing="8">
        <Label text="System Information" styleClass="section-title"/>
        <HBox spacing="32">
            <VBox spacing="4">
                <Label text="APPLICATION" styleClass="info-key"/>
                <Label text="Kiosks BackOffice" styleClass="info-val"/>
            </VBox>
            <VBox spacing="4">
                <Label text="VERSION" styleClass="info-key"/>
                <Label text="1.0.0 — IPVC 2025/2026" styleClass="info-val"/>
            </VBox>
            <VBox spacing="4">
                <Label text="CORE API" styleClass="info-key"/>
                <Label text="http://localhost:8090" styleClass="info-val"/>
            </VBox>
            <VBox spacing="4">
                <Label text="STATUS" styleClass="info-key"/>
                <Label text="● Connected" styleClass="info-val status-connected"/>
            </VBox>
        </HBox>
    </VBox>

</VBox>
