<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pt.ipvc.kiosks.desktop.controller.ProductsController"
      styleClass="view-root" spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Product Management" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Store filter:"/>
        <ComboBox fx:id="cmbStore" prefWidth="200"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="Search by name or SKU…" prefWidth="240"
                   onAction="#handleSearch"/>
        <ComboBox fx:id="cmbCategory" prefWidth="200"/>
        <Button text="Search" onAction="#handleSearch" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tableProducts" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"     text="Name"      prefWidth="200"/>
            <TableColumn fx:id="colPrice"    text="Price"     prefWidth="80"/>
            <TableColumn fx:id="colSku"      text="SKU"       prefWidth="110"/>
            <TableColumn fx:id="colCategory" text="Category"  prefWidth="120"/>
            <TableColumn fx:id="colStores"   text="Stores"    prefWidth="180"/>
            <TableColumn fx:id="colActive"   text="Status"    prefWidth="70"/>
        </columns>
        <placeholder><Label text="No products for the current selection."/></placeholder>
    </TableView>

    <VBox styleClass="form-card" spacing="10">
        <Label fx:id="lblFormTitle" text="New Product" styleClass="card-title"/>
        <GridPane hgap="12" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="160" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="160" hgrow="ALWAYS"/>
            </columnConstraints>

            <HBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="2">
                <Label text="Name"/><Label text=" *" styleClass="required-mark"/>
            </HBox>
            <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <HBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="2">
                <Label text="Price (€)"/><Label text=" *" styleClass="required-mark"/>
            </HBox>
            <TextField fx:id="txtPrice" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <Label text="SKU:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtSku" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <HBox GridPane.columnIndex="2" GridPane.rowIndex="1" spacing="2">
                <Label text="Category"/><Label text=" *" styleClass="required-mark"/>
            </HBox>
            <ComboBox fx:id="cmbFormCategory" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="txtDescription" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="3"/>

            <Label text="Image URL:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="txtImageUrl" promptText="https://…" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.columnSpan="3"/>

            <!-- store checkboxes are generated in code inside this VBox -->
            <HBox GridPane.columnIndex="0" GridPane.rowIndex="4" spacing="2">
                <Label text="Stores"/><Label text=" *" styleClass="required-mark"/>
            </HBox>
            <VBox fx:id="vboxStores" spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.columnSpan="3"/>
        </GridPane>
        <Label text="* Required field" styleClass="required-hint"/>
        <HBox spacing="8">
            <Button fx:id="btnSave"       text="Save Product"       onAction="#handleSave"       styleClass="btn-primary"/>
            <Button text="Enable / Disable" onAction="#handleDeactivate" styleClass="btn-secondary"/>
            <Button fx:id="btnDelete"     text="Delete"             onAction="#handleDelete"     styleClass="btn-danger"/>
            <Button fx:id="btnCancelEdit" text="Cancel"             onAction="#handleCancelEdit" styleClass="btn-secondary"/>
        </HBox>
        <Label fx:id="lblStatus" styleClass="status-label" wrapText="true"/>
    </VBox>
</VBox>
