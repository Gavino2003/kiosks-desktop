<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pt.ipvc.kiosks.desktop.controller.LoginController"
            styleClass="login-root">

    <top>
        <VBox alignment="CENTER" spacing="6" styleClass="login-header">
            <Label text="Kiosks BackOffice" styleClass="login-title"/>
            <Label text="Kiosk Management System" styleClass="login-subtitle"/>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 40 0 0 0;">
            <VBox alignment="CENTER" spacing="14" styleClass="login-card" maxWidth="380">
                <Label text="Sign In" styleClass="card-title"/>

                <VBox spacing="4">
                    <Label text="Username" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="Enter your username"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="Enter your password"
                                  onAction="#handleLogin"/>
                </VBox>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <Button text="Sign In" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity"/>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="login-footer-bar">
            <Label text="IPVC — Project II 2025/2026" styleClass="login-footer"/>
        </HBox>
    </bottom>

</BorderPane>
